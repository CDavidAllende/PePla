{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "oder",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "string"
    },
    "total": {
      "type": "decimal"
    },
    "orderStatus": {
      "type": "enumeration",
      "enum": [
        "processing",
        "shipped",
        "delivered",
        "cancelled"
      ]
    },
    "items": {
      "type": "json"
    },
    "order": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "user"
    },
    "date": {
      "type": "datetime"
    },
    "customerName": {
      "type": "string"
    },
    "customerEmail": {
      "type": "email"
    },
    "customerPhone": {
      "type": "string"
    },
    "customerAddress": {
      "type": "text"
    },
    "archived": {
      "type": "boolean",
      "default": false
    }
  }
}
